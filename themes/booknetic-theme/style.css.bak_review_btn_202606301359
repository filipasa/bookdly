/*
Theme Name: Bookdly
Theme URI: https://bookdly.co.uk
Author: Bookdly
Description: A polished, product-led booking platform landing page theme.
Version: 3.0
*/
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500&display=swap');




  :root{
    --ink:#0B0B12;
    --violet:#6c70dc;
    --violet-deep:#2E2A66;
    --violet-tint:#F2F1FC;
    --violet-line: rgba(108,112,220,0.28);
    --paper:#ffffff;
    --grey:#65636f;
    --grey-light:#9b99a6;
    --radius:2px;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    font-family:'Inter',sans-serif;
    color:var(--ink);
    background:var(--paper);
    line-height:1.5;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3{font-family:'Space Grotesk',sans-serif;}
  .mono{font-family:'IBM Plex Mono',monospace;}
  .wrap{max-width:1180px; margin:0 auto; padding:0 32px;}
  a{color:inherit; text-decoration:none;}
  img{max-width:100%; display:block;}

  /* ===== Annotation chrome for wireframe brief ===== */
  .section-tag{
    position:absolute; top:14px; left:14px;
    font-family:'IBM Plex Mono',monospace; font-size:11px;
    background:var(--ink); color:#fff; padding:4px 9px;
    border-radius:2px; letter-spacing:0.05em; z-index:20; opacity:0.82;
  }
  section, header, footer{position:relative;}

  /* ===== Nav ===== */
  header.nav{
    position:sticky; top:0; z-index:50;
    background:rgba(255,255,255,0.92); backdrop-filter:blur(8px);
    border-bottom:1px solid var(--violet-line);
  }
  .nav-inner{ display:flex; align-items:center; justify-content:space-between; height:72px;}
  .logo{font-family:'Space Grotesk'; font-weight:700; font-size:19px; display:flex; align-items:center; gap:8px;}
  .logo img.mark{height:26px; width:auto; display:block;}
  nav.links{display:flex; gap:36px; font-size:14px; font-weight:500; color:var(--grey);}
  .btn{
    display:inline-flex; align-items:center; justify-content:center;
    padding:11px 22px; border-radius:2px; font-size:14px; font-weight:600;
    cursor:pointer; transition:opacity .15s ease;
  }
  .btn:hover{opacity:0.88;}
  .btn-primary{background:var(--violet); color:#fff;}
  .btn-ghost{background:transparent; color:var(--ink); border:1px solid var(--ink);}
  .btn-ghost-light{background:transparent !important; color:#fff !important; border:1px solid rgba(255,255,255,0.25) !important;}

  /* ===== Hero ===== */
  .hero{
    min-height:88vh; display:flex; align-items:center;
    background-image:
      linear-gradient(rgba(108,112,220,.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(108,112,220,.08) 1px, transparent 1px);
    background-size: 48px 48px;
    padding:64px 0 40px;
  }
  .hero-grid{display:grid; grid-template-columns:1.05fr 0.95fr; gap:48px; align-items:center;}
  .eyebrow{
    font-family:'IBM Plex Mono', monospace; font-size:12px; letter-spacing:0.08em; text-transform:uppercase;
    color:var(--violet-deep); display:flex; align-items:center; gap:8px; margin-bottom:18px;
  }
  .eyebrow::before{content:''; width:6px; height:6px; background:var(--violet); border-radius:50%; display:inline-block;}
  .hero h1{font-size:50px; line-height:1.06; margin-bottom:22px;}
  .hero h1 .accent{color:var(--violet);}
  .hero p.sub{font-size:18px; color:var(--grey); max-width:480px; margin-bottom:32px;}
  .cta-row{display:flex; gap:14px; margin-bottom:18px;}
  .btn-lg{padding:15px 28px; font-size:15px;}
  .hero .btn-ghost{border:1px solid var(--ink) !important;}
  .micro-trust{font-size:13px; color:var(--grey-light);}

  /* hero mock calendar */
  .calendar-card{
    background:#fff; border:1px solid #e7e6f4; border-radius:6px;
    box-shadow:0 30px 60px -20px rgba(46,42,102,0.25);
    overflow:hidden;
  }
  .cal-head{
    display:flex; justify-content:space-between; align-items:center;
    padding:14px 18px; border-bottom:1px solid #eeeefa; background:var(--violet-tint);
  }
  .cal-head .mono{color:var(--violet-deep);}
  .cal-dots span{display:inline-block; width:7px; height:7px; border-radius:50%; background:#d8d7ef; margin-left:5px;}
  .cal-body{display:grid; grid-template-columns:54px repeat(5,1fr);}
  .cal-time{font-family:'IBM Plex Mono', monospace; font-size:10px; color:var(--grey-light); padding:10px 8px; border-right:1px solid #f1f0fa;}
  .cal-col-head{font-family:'IBM Plex Mono', monospace; font-size:10px; text-align:center; padding:8px 4px; color:var(--grey); border-bottom:1px solid #f1f0fa; border-right:1px solid #f1f0fa;}
  .cal-cell{height:38px; border-bottom:1px solid #f4f3fb; border-right:1px solid #f4f3fb; position:relative;}
  .appt{
    position:absolute; inset:3px; border-radius:3px; background:var(--violet); color:#fff;
    font-size:9px; font-weight:600; padding:3px 5px; opacity:0;
    animation:fadeBlock .5s ease forwards;
  }
  .appt.alt{background:var(--violet-deep);}
  .appt.confirmed::after{content:'✓'; float:right;}
  @keyframes fadeBlock{ to{opacity:1; transform:translateY(0);} from{opacity:0; transform:translateY(4px);} }
  .appt:nth-of-type(1){animation-delay:.3s;}
  .appt:nth-of-type(2){animation-delay:.55s;}
  .appt:nth-of-type(3){animation-delay:.8s;}
  .appt:nth-of-type(4){animation-delay:1.05s;}
  @media (prefers-reduced-motion: reduce){ .appt{animation:none; opacity:1;} }

  /* ===== Proof bar ===== */
  .proof{ background:var(--ink); color:#fff; padding:26px 0;}
  .proof-inner{display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:24px;}
  .proof-stats{display:flex; gap:48px;}
  .stat b{font-family:'Space Grotesk'; font-size:24px; color:var(--violet); display:block;}
  .stat span{font-size:12px; color:#9c9aae; font-family:'IBM Plex Mono', monospace; letter-spacing:.05em;}
  .logo-row{display:flex; gap:34px; align-items:center; opacity:0.55; filter:grayscale(1);}
  .logo-row .lg{font-family:'Space Grotesk'; font-weight:600; font-size:15px;}

  /* ===== Problem / Solution ===== */
  .ps{display:grid; grid-template-columns:1fr 1fr;}
  .ps > div{padding:90px 56px;}
  .ps .problem{background:var(--ink); color:#fff;}
  .ps .solution{background:var(--violet-tint);}
  .ps h2{font-size:30px; margin:14px 0 24px; max-width:380px;}
  .ps ul{list-style:none;}
  .ps li{display:flex; gap:14px; margin-bottom:20px; font-size:15px; align-items:flex-start; max-width:380px;}
  .ps .problem li{color:#cfcde0;}
  .ps .solution li{color:#34325a;}
  .bullet-x, .bullet-check{
    flex:none; width:22px; height:22px; border-radius:50%; display:flex; align-items:center; justify-content:center;
    font-size:11px; font-weight:700; margin-top:1px;
  }
  .bullet-x{background:rgba(255,255,255,0.12); color:#ff9b9b;}
  .bullet-check{background:var(--violet); color:#fff;}
  .ps .eyebrow{color:inherit; opacity:0.7;}
  .ps .problem .eyebrow::before{background:#ff9b9b;}
  .ps .solution .eyebrow{color:var(--violet-deep);}

  /* ===== Features ===== */
  .features{padding:110px 0;}
  .section-head{max-width:560px; margin-bottom:64px;}
  .section-head h2{font-size:34px; margin-top:14px;}
  .feature-row{
    display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center;
    padding:56px 0; border-top:1px solid var(--violet-line);
  }
  .feature-row:first-of-type{border-top:1px solid var(--violet-line);}
  .feature-row.rev .ftext{order:2;}
  .feature-row.rev .fvisual{order:1;}
  .ftext .mono{color:var(--violet-deep); margin-bottom:10px; display:block;}
  .ftext h3{font-size:24px; margin-bottom:12px;}
  .ftext p{color:var(--grey); margin-bottom:18px; max-width:420px;}
  .ftext .sublist{list-style:none; font-size:14px; color:var(--ink);}
  .ftext .sublist li{padding:6px 0; border-top:1px dashed #e3e2f0; display:flex; gap:8px;}
  .ftext .sublist li::before{content:'—'; color:var(--violet);}
  .fvisual{
    background:var(--violet-tint); border:1px solid #e7e6f4; border-radius:6px; height:300px;
    display:flex; align-items:center; justify-content:center; color:var(--grey-light);
    font-family:'IBM Plex Mono', monospace; font-size:12px; overflow:hidden; padding:18px;
  }
  .fvisual.img img{ width:100%; height:100%; object-fit:contain; }

  /* ===== Testimonials ===== */
  .testi{background:var(--violet-tint); padding:100px 0;}
  .testi-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:24px; margin-top:48px;}
  .t-card{background:#fff; border:1px solid #e7e6f4; border-radius:4px; padding:28px; display:flex; flex-direction:column; gap:16px;}
  .stars{color:var(--violet); font-size:13px; letter-spacing:2px;}
  .t-card p{font-size:15px; color:var(--ink);}
  .t-person{display:flex; gap:12px; align-items:center; margin-top:auto;}
  .avatar{width:38px; height:38px; border-radius:50%; background:var(--violet-deep); color:#fff; display:flex; align-items:center; justify-content:center; font-size:13px; font-family:'Space Grotesk'; font-weight:600;}
  .t-person .name{font-size:13px; font-weight:600;}
  .t-person .role{font-size:12px; color:var(--grey-light);}
  .t-card.featured{border-color:var(--violet); position:relative;}
  .t-card.featured::before{content:'▶ VIDEO'; font-family:'IBM Plex Mono', monospace; font-size:10px; position:absolute; top:16px; right:16px; color:var(--violet);}

  /* ===== Pricing ===== */
  .pricing{padding:110px 0;}
  
  .pricing-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 48px;
  }
  .pricing-toggle-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--grey);
  }
  
  /* Toggle Switch */
  .toggle-switch {
    position: relative;
    display: inline-block;
    width: 44px;
    height: 24px;
    cursor: pointer;
  }
  .toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
    position: absolute;
  }
  .toggle-slider {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: #e3e2f0;
    transition: .3s;
    border-radius: 24px;
  }
  .toggle-slider:before {
    position: absolute;
    content: "";
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    transition: .3s;
    border-radius: 50%;
  }
  .toggle-switch input:checked + .toggle-slider {
    background-color: var(--violet);
  }
  .toggle-switch input:checked + .toggle-slider:before {
    transform: translateX(20px);
  }
  
  /* Pricing Cards Layout */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
    margin-top: 48px;
  }
  
  .pricing-card {
    border: 1px solid #e7e6f4;
    border-radius: 6px;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    position: relative;
    box-sizing: border-box;
    min-height: 520px;
  }
  
  .pricing-card-featured {
    border: 2px solid var(--violet);
    transform: translateY(-12px);
    box-shadow: 0 30px 50px -25px rgba(108,112,220,0.4);
  }
  
  .pricing-badge {
    position: absolute;
    top: -13px;
    left: 28px;
    background: var(--violet);
    color: #fff;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: .06em;
    padding: 5px 10px;
    border-radius: 2px;
    text-transform: uppercase;
  }
  
  .pricing-plan-name {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    letter-spacing: .06em;
    color: var(--grey);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  
  .pricing-desc {
    font-size: 14px;
    color: var(--grey);
    margin-bottom: 24px;
    line-height: 1.6;
  }
  
  .pricing-price {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 38px;
    font-weight: 600;
    margin: 0 0 24px;
    display: flex;
    align-items: baseline;
    color: var(--ink);
  }
  .price-currency {
    font-size: 24px;
    align-self: flex-start;
    margin-top: 4px;
  }
  .price-period {
    font-size: 14px;
    color: var(--grey);
    font-weight: 400;
    margin-left: 4px;
  }
  
  .pricing-features {
    list-style: none !important;
    margin: 0 0 32px !important;
    padding: 0 !important;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .pricing-feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--ink);
  }
  .pricing-feature.disabled {
    opacity: 0.5;
  }
  
  .pricing-feature .check {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    flex-shrink: 0;
    background: rgba(108,112,220,0.1);
    color: var(--violet);
  }
  .pricing-feature.disabled .check {
    background: #f1f0fa;
    color: var(--grey-light);
  }
  
  .pricing-card .btn {
    margin-top: auto;
  }
  
  .pricing-card .btn-outline {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink) !important;
  }
  .pricing-card .btn-outline:hover {
    background: rgba(46,42,102,0.03);
  }
  .pricing-card .btn-primary {
    border: 1px solid var(--violet) !important;
  }
  
  .guarantee {
    text-align: center;
    font-size: 13px;
    color: var(--grey);
    margin-top: 36px;
  }

  /* Database Pricing List Reset */
  .plan .pnote-features { margin-bottom: 28px; }
  .plan .pnote-features ul, .plan ul.pricing-features {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
    display: flex !important;
    flex-direction: column !important;
  }
  .plan .pnote-features li, .plan li.pricing-feature {
    padding: 10px 0 !important;
    border-top: 1px solid #f1f0fa !important;
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    color: var(--ink) !important;
    font-size: 14px !important;
    font-family: 'Inter', sans-serif !important;
    background: none !important;
    margin: 0 !important;
    line-height: 1.5 !important;
  }
  .plan .pnote-features li::before, .plan li.pricing-feature::before {
    content: '✓' !important;
    color: var(--violet) !important;
    font-weight: 700 !important;
  }
  .plan .pnote-features li .check, .plan li.pricing-feature .check,
  .plan .pnote-features li span.check, .plan li.pricing-feature span.check {
    display: none !important;
  }
  .plan .pnote-features li span, .plan li.pricing-feature span {
    font-family: 'Inter', sans-serif !important;
    color: var(--ink) !important;
    background: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .cta-band{background:var(--ink); color:#fff; padding:80px 0; text-align:center;}
  .cta-band h2{font-size:32px; max-width:620px; margin:0 auto 28px;}
  .cta-band .cta-row{justify-content:center;}

  /* ===== FAQ ===== */
  .faq{padding:110px 0; max-width:760px; margin:0 auto;}
  .faq-item{border-top:1px solid var(--violet-line); padding:26px 0;}
  .faq-item:last-child{border-bottom:1px solid var(--violet-line);}
  .faq-q{display:flex; justify-content:space-between; align-items:center; cursor:pointer; font-size:17px; font-weight:600; font-family:'Space Grotesk';}
  .faq-q .idx{font-family:'IBM Plex Mono', monospace; font-size:12px; color:var(--violet-deep); margin-right:14px;}
  .faq-toggle{font-size:18px; color:var(--violet); transition:transform .2s;}
  .faq-item.open .faq-toggle{transform:rotate(45deg);}
  .faq-a{font-size:15px; color:var(--grey); max-height:0; overflow:hidden; transition:max-height .25s ease;}
  .faq-item.open .faq-a{max-height:200px; margin-top:14px;}

  footer{background:#fff; border-top:1px solid var(--violet-line); padding:40px 0; display:flex; justify-content:space-between; align-items:center;}
  footer .mono{color:var(--grey-light);}

  @media(max-width:900px){
    .hero-grid, .ps, .feature-row, .testi-grid, .price-grid, .pricing-grid{grid-template-columns:1fr;}
    .feature-row.rev .ftext, .feature-row.rev .fvisual{order:initial;}
    .hero h1{font-size:36px;}
    .plan.pop, .pricing-card-featured{transform:none; margin-top: 12px; margin-bottom: 12px;}
    nav.links{display:none;}
    .faq{padding:60px 24px !important;}
  }
  :focus-visible{outline:2px solid var(--violet); outline-offset:2px;}


/* ============================================================
   WORDPRESS THEME SELECTOR MAPPING
   ============================================================ */

/* Header / Nav Integration */
#site-header {
  position: sticky;
  top: 0;
  z-index: 999999;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--violet-line);
  transition: all 0.3s ease;
}

#site-header nav {
  max-width: 1180px;
  margin: 0 auto;
  padding: 0 32px;
}

#site-header .nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72px;
}

#site-header .nav-logo {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 19px;
  display: flex;
  align-items: center;
  gap: 8px;
}

#site-header .logo-light {
  display: none !important;
}

#site-header .logo-dark {
  display: block !important;
  height: 28px;
  width: auto;
}

#site-header .nav-links {
  display: flex;
  gap: 36px;
  font-size: 14px;
  font-weight: 500;
  color: var(--grey);
}

#site-header .nav-links a {
  color: var(--grey);
  transition: color 0.2s ease;
}

#site-header .nav-links a:hover {
  color: var(--violet);
}

/* Header buttons and CTA */
#site-header .nav-cta {
  display: flex;
  align-items: center;
  gap: 16px;
}

#site-header .nav-login {
  font-size: 14px;
  font-weight: 500;
  color: var(--grey);
  transition: color 0.2s ease;
  white-space: nowrap;
  flex-shrink: 0;
}

#site-header .nav-login:hover {
  color: var(--violet);
}

/* Mobile Toggle Styles */
.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 8px;
  background: transparent;
  border: none;
}

.nav-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--ink);
  border-radius: 2px;
  transition: all 0.25s ease;
}

/* Footer Integration */
#site-footer {
  background: #ffffff;
  border-top: 1px solid var(--violet-line);
  padding: 64px 0 40px;
  color: var(--grey);
}

#site-footer .container {
  max-width: 1180px;
  margin: 0 auto;
  padding: 0 32px;
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  padding-bottom: 48px;
  border-bottom: 1px solid var(--violet-line);
}

.footer-brand p {
  font-size: 14px;
  line-height: 1.6;
  color: var(--grey);
  margin-top: 16px;
  margin-bottom: 24px;
  max-width: 320px;
}

.footer-socials {
  display: flex;
  gap: 12px;
}

.social-btn {
  width: 36px;
  height: 36px;
  border-radius: 4px;
  border: 1px solid var(--violet-line);
  background: transparent;
  color: var(--grey);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.social-btn:hover {
  background: var(--violet);
  color: #fff;
  border-color: var(--violet);
}

.footer-col h4 {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 20px;
}

.footer-col a {
  display: block;
  font-size: 14px;
  color: var(--grey);
  margin-bottom: 12px;
  transition: color 0.2s ease;
  text-decoration: none;
}

.footer-col a:hover {
  color: var(--violet);
}

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24px;
  font-size: 13px;
  color: var(--grey-light);
  flex-wrap: wrap;
  gap: 16px;
}

.footer-bottom-links {
  display: flex;
  gap: 24px;
}

.footer-bottom-links a {
  color: var(--grey-light);
  transition: color 0.2s ease;
  text-decoration: none;
}

.footer-bottom-links a:hover {
  color: var(--violet);
}

.nav-overlay {
  display: none;
}

/* Responsive adjustments */
@media (max-width: 900px) {
  .nav-overlay {
    display: block !important;
    position: fixed !important;
    top: 72px !important;
    left: 0 !important;
    width: 100vw !important;
