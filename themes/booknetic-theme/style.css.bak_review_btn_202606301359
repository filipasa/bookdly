/* ===== Split layout ===== */
  .auth-shell{display:grid; grid-template-columns:1fr 1fr; min-height:calc(100vh - 49px);}
  .brand-panel{
    background:var(--violet-deep); color:#fff; padding:56px; display:flex; flex-direction:column; justify-content:space-between;
    position:relative; overflow:hidden;
    background-image: repeating-linear-gradient(to bottom, transparent, transparent 39px, rgba(255,255,255,0.06) 39px, rgba(255,255,255,0.06) 40px);
    background-size:100% 40px;
  }
  .brand-top .logo{display:flex; align-items:center; gap:10px; font-family:'Space Grotesk'; font-weight:700; font-size:19px;}
  .brand-top .logo img{height:26px;}

  .brand-mid{max-width:380px;}
  .brand-mid .eyebrow{font-family:'IBM Plex Mono'; font-size:12px; letter-spacing:.08em; text-transform:uppercase; color:#b9b8e8; display:flex; align-items:center; gap:8px; margin-bottom:16px;}
  .brand-mid .eyebrow::before{content:''; width:6px; height:6px; background:var(--violet); border-radius:50%; display:inline-block;}
  .brand-mid h2{font-size:30px; line-height:1.15; margin-bottom:14px;}
  .brand-mid p{color:#c9c8ec; font-size:15px;}

  /* mini calendar mock reused from landing page, scaled down */
  .brand-panel .calendar-card{background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.15); border-radius:6px; overflow:hidden; margin-top:28px;}
  .brand-panel .cal-head{display:flex; justify-content:space-between; align-items:center; padding:10px 14px; border-bottom:1px solid rgba(255,255,255,0.1);}
  .brand-panel .cal-head .mono{color:#cfcef0;}
  .brand-panel .cal-dots span{display:inline-block; width:6px; height:6px; border-radius:50%; background:rgba(255,255,255,0.25); margin-left:4px;}
  .brand-panel .cal-body{display:grid; grid-template-columns:repeat(5,1fr);}
  .brand-panel .cal-col-head{font-family:'IBM Plex Mono'; font-size:9px; text-align:center; padding:6px 2px; color:#a7a6d8; border-bottom:1px solid rgba(255,255,255,0.08); border-right:1px solid rgba(255,255,255,0.06);}
  .brand-panel .cal-cell{height:28px; border-bottom:1px solid rgba(255,255,255,0.06); border-right:1px solid rgba(255,255,255,0.06); position:relative;}
  .brand-panel .appt{position:absolute; inset:2px; border-radius:2px; background:var(--violet); font-size:8px;}

  .brand-bottom{display:flex; gap:48px;}
  .brand-stat b{font-family:'Space Grotesk'; font-size:20px; display:block;}
  .brand-stat span{font-size:11px; color:#a7a6d8; font-family:'IBM Plex Mono'; letter-spacing:.05em;}

  /* ===== Form panel ===== */
  .form-panel{display:flex; align-items:center; justify-content:center; padding:56px;}
  .form-card{width:100%; max-width:380px; margin: 0 auto;}
  .form-card .top-logo{display:none;} /* shown on mobile only */
  .form-card .eyebrow{color:var(--violet-deep);}
  .form-card h1{font-size:28px; margin-bottom:8px;}
  .form-card .lede{color:var(--grey); font-size:15px; margin-bottom:32px;}

  .field{margin-bottom:18px;}
  .field label{display:block; font-size:13px; font-weight:600; margin-bottom:7px;}
  .field input{
    width:100%; padding:12px 14px; border:1px solid #e3e2f0; border-radius:2px; font-size:15px;
    font-family:'Inter'; background:#fafaff; transition:border-color .15s;
  }
  .field input:focus{outline:none; border-color:var(--violet); background:#fff;}
  .field-hint{font-size:12px; color:var(--grey-light); margin-top:6px;}

  .row-between{display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; font-size:13px;}
  .checkbox-row{display:flex; align-items:center; gap:8px; color:var(--grey);}
  .checkbox-row input{width:15px; height:15px; accent-color:var(--violet);}
  .link-violet{color:var(--violet-deep); font-weight:600;}

  .btn{display:inline-flex; align-items:center; justify-content:center; gap:8px; width:100%; padding:14px; border-radius:2px; font-size:15px; font-weight:600; cursor:pointer; border:none;}
  .btn-primary{background:var(--violet); color:#fff;}
  .btn-primary:hover{opacity:.9;}

  .divider{display:flex; align-items:center; gap:12px; margin:28px 0; color:var(--grey-light); font-size:12px; font-family:'IBM Plex Mono';}
  .divider::before, .divider::after{content:''; flex:1; height:1px; background:#e3e2f0;}

  .btn-social{
    width:100%; display:flex; align-items:center; justify-content:center; gap:10px; padding:12px; border:1px solid #e3e2f0;
    border-radius:2px; font-size:14px; font-weight:500; background:#fff; cursor:pointer; margin-bottom:10px; color:var(--ink);
  }
  .btn-social:hover{background:#fafaff;}
  .switch-link{text-align:center; margin-top:28px; font-size:14px; color:var(--grey);}

  .terms-note{font-size:12px; color:var(--grey-light); margin-top:18px; line-height:1.5;}

  /* Forgot password success state */
  .success-state{display:none; text-align:center;}
  .success-state.show{display:block;}
  .success-state .icon-circle{
    width:56px; height:56px; border-radius:50%; background:var(--violet-tint); color:var(--violet-deep);
    display:flex; align-items:center; justify-content:center; font-size:22px; margin:0 auto 20px;
  }
  .success-state h1{font-size:24px; margin-bottom:10px;}
  .success-state p{color:var(--grey); font-size:14px; margin-bottom:8px;}
  .success-state .email-chip{font-weight:600; color:var(--ink);}
  .resend{font-size:13px; color:var(--grey-light); margin-top:24px;}
  .resend a{color:var(--violet-deep); font-weight:600;}

  .form-default{display:block;}
  .form-default.hide{display:none;}

  /* annotation tags */
  .annot{position:absolute; top:10px; left:10px; background:var(--ink); color:#fff; font-family:'IBM Plex Mono'; font-size:10px; padding:4px 8px; border-radius:2px; opacity:.85; letter-spacing:.04em;}
  .form-panel{position:relative;}
  .brand-panel{position:relative;}

  @media(max-width:900px){
    .auth-shell{grid-template-columns:1fr;}
    .brand-panel{display:none;}
    .form-card .top-logo{display:flex; align-items:center; gap:9px; font-family:'Space Grotesk'; font-weight:700; font-size:18px; margin-bottom:40px;}
    .form-card .top-logo img{height:24px;}
  }


