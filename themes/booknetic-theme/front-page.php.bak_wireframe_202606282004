      <?php
      if (!empty($plans)):
          $currency_symbol = '£';
          if (class_exists('BookneticSaaS\Providers\Helpers\Helper')) {
              $currency_symbol = BookneticSaaS\Providers\Helpers\Helper::currencySymbol();
          }
          
          foreach ($plans as $index => $plan):
              $is_featured = ($plan->is_default == 1);
              $delay_class = 'reveal-delay-' . ($index + 1);
              $card_class = 'pricing-card reveal ' . $delay_class;
              if ($is_featured) {
                  $card_class = 'pricing-card featured reveal ' . $delay_class;
              }
              
              // Parse description
              $description = $plan->description ?? '';
              $pricing_name = '';
              $pricing_desc = '';
              $features = [];
              $pricing_features_html = '';
              
              if (strpos($description, '---') !== false) {
                  $parts = explode('---', $description, 2);
                  $meta = trim($parts[0]);
                  $features_raw = trim($parts[1]);
                  
                  if (strpos($meta, '|') !== false) {
                      list($pricing_name, $pricing_desc) = array_map('trim', explode('|', $meta, 2));
                  } else {
                      $pricing_desc = $meta;
                  }
                  
                  if (!empty($features_raw)) {
                      $features = array_filter(array_map('trim', explode("\n", $features_raw)));
                  }
              } else {
                  if (strpos($description, '<ul') !== false) {
                      list($pricing_desc, $pricing_features_html) = explode('<ul', $description, 2);
                      $pricing_features_html = '<ul' . $pricing_features_html;
                  } else {
                      $pricing_desc = $description;
                  }
              }
              
              // Button text
              $btn_text = 'Choose Plan';
              if ($plan->monthly_price == 0) {
                  $btn_text = 'Get started free';
              } elseif ($is_featured) {
                  $trial_days = class_exists('BookneticSaaS\Providers\Helpers\Helper') ? BookneticSaaS\Providers\Helpers\Helper::getOption('trial_period', 14) : 14;
                  $btn_text = 'Start ' . $trial_days . '-day free trial';
              }
              ?>
              <div class="<?php echo esc_attr($card_class); ?>">
                  <?php if ($is_featured || !empty($plan->ribbon_text)): ?>
                      <div class="pricing-badge"><?php echo esc_html($plan->ribbon_text ?: 'Most Popular'); ?></div>
                  <?php endif; ?>
                  
                  <div class="pricing-plan"><?php echo esc_html($plan->name); ?></div>
                  
                  <?php if (!empty($pricing_name)): ?>
                      <div class="pricing-name"><?php echo esc_html($pricing_name); ?></div>
                  <?php endif; ?>
                  
                  <?php if (!empty($pricing_desc)): ?>
                      <div class="pricing-desc"><?php echo wp_kses_post($pricing_desc); ?></div>
                  <?php endif; ?>
                  
                  <div class="pricing-price">
                      <span class="price-currency"><?php echo esc_html($currency_symbol); ?></span>
                      <span class="price-amount" data-monthly="<?php echo esc_attr(round($plan->monthly_price)); ?>" data-annual="<?php echo esc_attr(round($plan->annually_price)); ?>"><?php echo esc_html(round($plan->monthly_price)); ?></span>
                      <span class="price-period">/mo</span>
                  </div>
                  
                  <?php if (!empty($pricing_features_html)): ?>
                      <?php echo wp_kses_post($pricing_features_html); ?>
                  <?php endif; ?>
                  
                  <?php if (!empty($features)): ?>
                      <ul class="pricing-features">
                          <?php foreach ($features as $feature): 
                              $is_disabled = (strpos($feature, '-') === 0 || strpos($feature, '—') === 0 || strpos($feature, 'x ') === 0);
                              $clean_feature = ltrim($feature, '-—x ');
                              ?>
                              <li class="pricing-feature <?php echo $is_disabled ? 'disabled' : ''; ?>">
                                  <span class="check"><?php echo $is_disabled ? '—' : '✓'; ?></span>
                                  <?php echo esc_html($clean_feature); ?>
                              </li>
                          <?php endforeach; ?>
                      </ul>
                  <?php endif; ?>
                  
                  <a href="<?php echo esc_url( home_url('/sign-up/?plan_id=' . $plan->id) ); ?>" class="btn <?php echo $is_featured ? 'btn-primary' : 'btn-outline'; ?>"><?php echo esc_html($btn_text); ?></a>
